#!/usr/bin/env bash
# Auto-append a CHANGELOG.md entry on every commit to develop.
# Runs after pre-commit (so version is already bumped in pubspec.yaml).
# Stages CHANGELOG.md — it lands in the same commit as the code change.

BRANCH=$(git branch --show-current)
[ "$BRANCH" = "develop" ] || exit 0

COMMIT_SOURCE="${2:-}"
# Only for regular commits (-m or editor). Skip merge/squash/amend.
[ -z "$COMMIT_SOURCE" ] || [ "$COMMIT_SOURCE" = "message" ] || exit 0

MSG=$(grep -v '^#' "$1" | head -1 | xargs)
[ -n "$MSG" ] || exit 0

CHANGELOG="CHANGELOG.md"
DATE=$(date +%Y-%m-%d)
VERSION=$(grep "^version:" app/pubspec.yaml | sed 's/^version: *//')

# Idempotent — skip if this version already has an entry
[ -f "$CHANGELOG" ] && grep -q "^## \[${VERSION}\]" "$CHANGELOG" && exit 0

TMP=$(mktemp)
if [ -f "$CHANGELOG" ]; then
    # Splice new entry after the header line
    head -2 "$CHANGELOG" > "$TMP"
    printf "## [%s] — %s\n- %s\n\n" "$VERSION" "$DATE" "$MSG" >> "$TMP"
    tail -n +3 "$CHANGELOG" >> "$TMP"
else
    printf "# Changelog\n\n## [%s] — %s\n- %s\n\n" "$VERSION" "$DATE" "$MSG" > "$TMP"
fi
mv "$TMP" "$CHANGELOG"
git add "$CHANGELOG"
