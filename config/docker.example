# Docker environment variables for bakery-shop
#
# Copy this file to .env at the project root:
#   cp config/docker.example .env
#
# Docker Compose auto-reads .env — no need to export manually.
# All tool/ scripts also source .env for consistency.

# Tailscale domain for HTTPS (used by Caddy and cert renewal)
DOMAIN=drgnfly.tail10c2c6.ts.net

# Rustic profile name for backup/restore (must match ~/.config/rustic/<name>.toml)
RUSTIC_PROFILE=baker-prod

# Host thermal printer device mounted into baker-prod at /dev/usb/lp0.
# Set to /dev/null when BAKER_PRINT_IPP_URL is set (no local printer needed).
BAKER_PRINTER_DEVICE=/dev/usb/lp0

# IPP printer endpoint for network printing via CUPS.
# When set, baker sends pre-rendered TSPL bytes to this CUPS/IPP endpoint
# instead of writing directly to /dev/usb/lp0. Unset or empty = USB mode.
# Example (Lily CUPS over Tailscale):
#   BAKER_PRINT_IPP_URL=ipp://lily.tail10c2c6.ts.net:631/printers/Y41BT
# Then set BAKER_PRINTER_DEVICE=/dev/null (no local USB device needed).

# Printer paper type server default ("label" | "roll").
# "label" = pre-cut label stock with gaps (default, backward compatible).
# "roll"  = continuous roll paper (no fixed length, tear anywhere).
# Unset defaults to "label". Invalid values cause server startup to fail fast.
# Runtime override available via Settings → Technical tab (DB value takes precedence).
PAPER_MODE=label
