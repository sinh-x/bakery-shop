# Dev front-end for the bakery app, fronted by the central drgnfly-caddy
# gateway which terminates TLS on :443 for the tailnet FQDN and reverse-proxies
# the domain root here. This server listens plain HTTP on :80 (published to
# host loopback 127.0.0.1:2380 by docker-compose) and proxies /api/* to the
# dev backend while serving the Flutter web app with SPA fallback.
:80 {
	# Reverse proxy API requests to the dev baker backend (preserves /api/ prefix)
	handle /api/* {
		reverse_proxy baker-dev:2312
	}

	# Serve Flutter web app with SPA fallback
	handle {
		root * /srv/web

		# Force revalidation of mutable web assets so deploys propagate immediately
		@nocache path /index.html /main.dart.js /flutter_bootstrap.js /manifest.json /version.json /assets/FontManifest.json /assets/fonts/MaterialIcons-Regular.otf
		header @nocache Cache-Control "no-cache, must-revalidate"

		# Hashed assets can be cached long-term
		@assets {
			path /assets/* /canvaskit/*
			not path /assets/FontManifest.json /assets/fonts/MaterialIcons-Regular.otf
		}
		header @assets Cache-Control "public, max-age=31536000, immutable"

		try_files {path} /index.html
		file_server
	}
}
